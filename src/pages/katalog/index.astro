---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/site.js';
import { categories, productsByCategory } from '../../data/products.js';

const title = 'Каталог мебели и материалов из Китая — Relent';
const description =
  'Каталог: диваны, кресла, кровати, столы, освещение, сантехника, двери, плитка и камень напрямую с фабрик Китая. Аналоги брендовых моделей с экономией до 70%. Доставка по всей России.';

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Главная', item: SITE.url + '/' },
      { '@type': 'ListItem', position: 2, name: 'Каталог', item: SITE.url + '/katalog/' },
    ],
  },
];
---

<Base title={title} description={description} canonical="/katalog/" jsonld={jsonld}>
  <main class="subpage">
    <div class="wrap">
      <nav class="crumbs" aria-label="Хлебные крошки">
        <a href="/">Главная</a><span class="sep">/</span><span class="cur">Каталог</span>
      </nav>
      <div class="page-head">
        <h1>Каталог мебели и материалов из Китая</h1>
        <p class="page-lede">
          Комплектуем объекты «под ключ»: мебель, свет, сантехнику, двери и отделку — напрямую с
          проверенных фабрик Гуанчжоу, Фошаня и Шэньчжэня. Выберите категорию или пришлите свою позицию
          на бесплатный расчёт.
        </p>
      </div>

      <div class="card-grid">
        {categories.map((c) => (
          <a class="pcard" href={`/katalog/${c.slug}/`}>
            <div class="pcard-photo" style={`background-image:url('${c.image}')`}></div>
            <div class="pcard-body">
              <div class="pcard-name">{c.name}</div>
              <p style="color:var(--grey); font-size:13.5px; line-height:1.5; margin:2px 0;">{c.desc}</p>
              {productsByCategory(c.slug).length > 0 && (
                <div class="pcard-price"><b>{productsByCategory(c.slug).length}</b> аналогов брендов →</div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="cta-band">
      <div class="wrap">
        <div>
          <h2>Не нашли нужную позицию?</h2>
          <p>Пришлите ссылку, фото или дизайн-проект — подберём на фабрике и посчитаем цену за 24 часа.</p>
        </div>
        <a class="btn light" href="/kontakty/">Отправить на расчёт <span class="btn-arrow">→</span></a>
      </div>
    </div>
  </main>
</Base>
