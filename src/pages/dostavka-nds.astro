---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site.js';

const title = 'Доставка из Китая и вычет НДС — белая логистика | Relent';
const description =
  'Белая логистика из Китая с вычетом НДС: консолидация груза, таможенное оформление через партнёров и доставка мебели до объекта по всей России. Прозрачные документы.';

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Главная', item: SITE.url + '/' },
      { '@type': 'ListItem', position: 2, name: 'Доставка и НДС', item: SITE.url + '/dostavka-nds/' },
    ],
  },
];
---

<Base title={title} description={description} canonical="/dostavka-nds/" jsonld={jsonld}>
  <main class="subpage">
    <div class="wrap">
      <nav class="crumbs" aria-label="Хлебные крошки">
        <a href="/">Главная</a><span class="sep">/</span><span class="cur">Доставка и НДС</span>
      </nav>
      <div class="page-head">
        <h1>Доставка из Китая и вычет НДС</h1>
        <p class="page-lede">Белая логистика с полным пакетом документов: консолидируем груз, оформляем таможню через партнёров и доставляем до объекта в любую точку России.</p>
      </div>

      <div class="prose">
        <h2>Белая логистика и НДС</h2>
        <p>
          Работаем «в белую»: официальные документы на груз, таможенное оформление и возможность вычета
          НДС для юридических лиц. Вы получаете прозрачную цепочку от фабрики до объекта, без «серых» схем
          и сюрпризов на таможне.
        </p>
        <h2>Консолидация груза</h2>
        <p>
          Продукция от всех фабрик свозится на наш консолидационный склад, где мы проверяем артикулы на
          скрытые дефекты и комплектность, объединяем и переупаковываем груз для международной отправки.
          Это снижает стоимость перевозки и риск повреждений.
        </p>
        <h2>Доставка по России</h2>
        <p>
          Доставляем на объект по всей России — авто, ЖД или авиа, в зависимости от сроков и объёма.
          Рассчитываем логистику индивидуально под ваш проект и согласуем сроки заранее.
        </p>
        <ul class="checks">
          <li>Официальные документы и вычет НДС</li>
          <li>Таможенное оформление через партнёров</li>
          <li>Консолидация и переупаковка на складе в Китае</li>
          <li>Доставка до объекта в любую точку РФ</li>
        </ul>
      </div>
    </div>

    <div class="cta-band">
      <div class="wrap">
        <div>
          <h2>Посчитать логистику под ваш проект</h2>
          <p>Пришлите спецификацию — рассчитаем стоимость с доставкой до объекта.</p>
        </div>
        <a class="btn light" href="/kontakty/">Получить расчёт <span class="btn-arrow">→</span></a>
      </div>
    </div>
  </main>
</Base>
