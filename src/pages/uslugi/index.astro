---
import Base from '../../layouts/Base.astro';
import { SITE } from '../../data/site.js';
import { services } from '../../data/products.js';

const title = 'Что мы комплектуем: квартиры, дома, отели, коммерция — Relent';
const description =
  'Комплектация объектов мебелью и материалами из Китая под ключ: квартиры и апартаменты, частные дома, отели, коммерческие объекты, рестораны. Подбор, контроль качества, доставка по всей России.';

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Главная', item: SITE.url + '/' },
      { '@type': 'ListItem', position: 2, name: 'Что комплектуем', item: SITE.url + '/uslugi/' },
    ],
  },
];
---

<Base title={title} description={description} canonical="/uslugi/" jsonld={jsonld}>
  <main class="subpage">
    <div class="wrap">
      <nav class="crumbs" aria-label="Хлебные крошки">
        <a href="/">Главная</a><span class="sep">/</span><span class="cur">Что комплектуем</span>
      </nav>
      <div class="page-head">
        <h1>Что мы комплектуем</h1>
        <p class="page-lede">
          От студии до отеля — берём на себя полный цикл комплектации объекта мебелью, освещением и
          отделочными материалами напрямую с фабрик Китая. Гибкий подход под задачу и бюджет проекта.
        </p>
      </div>

      <div class="card-grid">
        {services.map((s) => (
          <a class="pcard" href={`/uslugi/${s.slug}/`}>
            <div class="pcard-photo" style={`background-image:url('${s.image}')`}></div>
            <div class="pcard-body">
              <div class="pcard-name">{s.name}</div>
              <p style="color:var(--grey); font-size:13.5px; line-height:1.5; margin:2px 0;">{s.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="cta-band">
      <div class="wrap">
        <div>
          <h2>Обсудим ваш объект?</h2>
          <p>Пришлите дизайн-проект или спецификацию — бесплатно подберём 10 позиций, чтобы вы увидели выгоду.</p>
        </div>
        <a class="btn light" href="/kontakty/">Отправить проект <span class="btn-arrow">→</span></a>
      </div>
    </div>
  </main>
</Base>
