---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site.js';

const title = 'Relent — Мебель и комплектация объектов из Китая под ключ';
const description =
  'Комплектуем объекты мебелью и отделочными материалами напрямую с фабрик Китая: подбор, контроль производства, инспекция качества, белая логистика с вычетом НДС и доставка по всей России.';

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    inLanguage: 'ru-RU',
  },
];
---

<Base title={title} description={description} jsonld={jsonld}>
  <main>
<section class="hero" id="top">
  <div class="hero-photo"></div>
  <svg class="hero-routes" viewBox="0 0 1280 800" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M -50 620 Q 300 500 620 560 T 1330 420" stroke="rgba(233,230,222,0.14)" stroke-width="1" fill="none"/>
    <path d="M -50 680 Q 340 590 700 640 T 1330 520" stroke="rgba(233,230,222,0.08)" stroke-width="1" fill="none"/>
    <circle cx="1100" cy="480" r="3" fill="#a9adaa"/>
    <circle cx="200" cy="600" r="3" fill="rgba(233,230,222,0.4)"/>
  </svg>
  <div class="hero-content">
    <div class="wrap">
      <div>
        <h1>Комплектация мебелью и&nbsp;материалами <em>напрямую из&nbsp;Китая</em>, под&nbsp;ключ</h1>
      </div>
      <div>
        <p class="lede">От подбора материалов и&nbsp;мебели до&nbsp;контроля производства, инспекции качества и&nbsp;доставки на&nbsp;объект.</p>
        <div class="hero-cta-group">
          <a class="btn light" href="#contact">Отправить проект <span class="btn-arrow">→</span></a>
          <div class="hero-cta-note">Бесплатный расчёт <strong>10 позиций</strong> проекта</div>
        </div>
      </div>
    </div>
  </div>
  <div class="wrap hero-foot">
    <div class="hero-meta">
      <div><strong>1</strong> подрядчик вместо десятков поставщиков</div>
      <div>Фабрики <strong>Гуанчжоу · Фошань · Шэньчжэнь</strong></div>
      <div>Контроль <strong>на каждом этапе</strong></div>
    </div>
  </div>
</section>

<section id="get">
  <div class="wrap">
    <div class="section-head reveal">
      <h2>Почему мы,<br>а&nbsp;не&nbsp;посредники?</h2>
      <p>Полный цикл комплектации — от&nbsp;чертежа до&nbsp;воплощения мечты — под&nbsp;ответственностью одной команды в&nbsp;Китае.</p>
    </div>
  </div>
  <div class="wrap">
    <div class="get-grid reveal">
      <div class="get-item">
        <svg class="stamp" viewBox="0 0 74 74"><circle cx="37" cy="37" r="33" stroke="var(--accent)" stroke-width="1"/><circle cx="37" cy="37" r="27" stroke="var(--accent)" stroke-width="1"/><path d="M25 38 L33 46 L50 27" stroke="var(--accent)" stroke-width="2" fill="none"/></svg>
        <div><h4>Один подрядчик</h4><p>Вместо множества подрядчиков — одна точка ответственности за&nbsp;весь проект.</p></div>
      </div>
      <div class="get-item">
        <svg class="stamp" viewBox="0 0 74 74"><circle cx="37" cy="37" r="33" stroke="var(--accent)" stroke-width="1"/><rect x="24" y="24" width="26" height="26" stroke="var(--accent)" stroke-width="1.3" fill="none"/><line x1="24" y1="34" x2="50" y2="34" stroke="var(--accent)" stroke-width="1"/></svg>
        <div><h4>Всё в&nbsp;рамках одного проекта</h4><p>Мебель, освещение, сантехника, двери, плитка и&nbsp;отделочные материалы — единым потоком.</p></div>
      </div>
      <div class="get-item">
        <svg class="stamp" viewBox="0 0 74 74"><circle cx="37" cy="37" r="33" stroke="var(--accent)" stroke-width="1"/><circle cx="37" cy="37" r="8" stroke="var(--accent)" stroke-width="1.3"/><line x1="37" y1="18" x2="37" y2="24" stroke="var(--accent)" stroke-width="1"/><line x1="37" y1="50" x2="37" y2="56" stroke="var(--accent)" stroke-width="1"/></svg>
        <div><h4>Контроль качества на&nbsp;фабриках</h4><p>Наши инспекторы проверяют производство на&nbsp;месте — в&nbsp;Гуанчжоу, Фошане, Шэньчжэне.</p></div>
      </div>
      <div class="get-item">
        <svg class="stamp" viewBox="0 0 74 74"><circle cx="37" cy="37" r="33" stroke="var(--accent)" stroke-width="1"/><rect x="22" y="27" width="30" height="20" rx="1" stroke="var(--accent)" stroke-width="1.3"/><circle cx="37" cy="37" r="5" stroke="var(--accent)" stroke-width="1"/></svg>
        <div><h4>Прозрачность каждого этапа</h4><p>Прогресс производства фиксируется и&nbsp;передаётся вам на&nbsp;каждом этапе. Регулярные фото и&nbsp;видеоотчёты.</p></div>
      </div>
      <div class="get-item">
        <svg class="stamp" viewBox="0 0 74 74"><circle cx="37" cy="37" r="33" stroke="var(--accent)" stroke-width="1"/><path d="M37 22 L48 27 V38 C48 46 43 51 37 53 C31 51 26 46 26 38 V27 Z" stroke="var(--accent)" stroke-width="1.2" fill="none"/></svg>
        <div><h4>Инспекция перед отгрузкой</h4><p>Проверка на&nbsp;брак и&nbsp;дефекты до&nbsp;того, как груз покинет фабрику.</p></div>
      </div>
      <div class="get-item">
        <svg class="stamp" viewBox="0 0 74 74"><circle cx="37" cy="37" r="33" stroke="var(--accent)" stroke-width="1"/><rect x="16" y="30" width="22" height="14" stroke="var(--accent)" stroke-width="1.3" fill="none"/><path d="M38 34 h8 l6 6 v4 h-14 z" stroke="var(--accent)" stroke-width="1.3" fill="none"/><circle cx="25" cy="46" r="3.2" stroke="var(--accent)" stroke-width="1.2" fill="none"/><circle cx="46" cy="46" r="3.2" stroke="var(--accent)" stroke-width="1.2" fill="none"/><line x1="12" y1="46" x2="18" y2="46" stroke="var(--accent)" stroke-width="1"/></svg>
        <div><h4>Логистика и&nbsp;доставка</h4><p>Белая логистика, вычет НДС. Консолидация грузов и&nbsp;бережная доставка на&nbsp;объект.</p></div>
      </div>
    </div>
  </div>
</section>

<section id="objects">
  <div class="wrap">
    <div class="section-head reveal">
      <h2>Какие проекты<br>мы комплектуем</h2>
      <p>От&nbsp;студии до&nbsp;отелей — гибкий подход под&nbsp;задачу и&nbsp;бюджет проекта.</p>
    </div>
    <div class="obj-grid reveal">
      <div class="obj-card">
        <div class="obj-bg" style="background-image:url('/images/obj-apartments.jpg')"></div>
        <div class="obj-overlay"></div>
        <div class="obj-content">
          <div class="obj-num">01</div>
          <div>
            <h4>Квартиры и апартаменты</h4>
            <p>Полная комплектация мебелью, освещением и отделочными материалами.</p>
          </div>
        </div>
      </div>
      <div class="obj-card">
        <div class="obj-bg" style="background-image:url('/images/obj-house.jpg')"></div>
        <div class="obj-overlay"></div>
        <div class="obj-content">
          <div class="obj-num">02</div>
          <div>
            <h4>Частные дома</h4>
            <p>Подбор и поставка всех материалов для реализации проекта.</p>
          </div>
        </div>
      </div>
      <div class="obj-card">
        <div class="obj-bg" style="background-image:url('/images/obj-hotel.jpg')"></div>
        <div class="obj-overlay"></div>
        <div class="obj-content">
          <div class="obj-num">03</div>
          <div>
            <h4>Отели</h4>
            <p>Комплектация номерного фонда, общественных зон и ресторанов.</p>
          </div>
        </div>
      </div>
      <div class="obj-card">
        <div class="obj-bg" style="background-image:url('/images/hero.jpg')"></div>
        <div class="obj-overlay"></div>
        <div class="obj-content">
          <div class="obj-num">04</div>
          <div>
            <h4>Коммерческие объекты</h4>
            <p>Офисы, шоурумы, рестораны и другие пространства.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="compare">
  <div class="wrap">
    <div class="section-head reveal">
      <h2>Одинаковое качество<br>за&nbsp;разные цены</h2>
      <p>Те&nbsp;же модели, тот&nbsp;же силуэт и&nbsp;материалы — но&nbsp;цена собирается на&nbsp;фабрике в&nbsp;Китае, а&nbsp;не&nbsp;в&nbsp;бутике в&nbsp;Милане.</p>
    </div>

    <div class="compare-list reveal">
      <div class="cmp-row">
        <div class="cmp-head">
          <div class="cmp-model">Диван Andersen</div>
          <div class="cmp-save">Выгода −70%</div>
        </div>
        <div class="cmp-pair">
          <div class="cmp-cell">
            <div class="cmp-photo" style="background-image:url('/images/product-sofa.jpg')"></div>
            <div>
              <div class="cmp-tag">Оригинал</div>
              <div class="cmp-origin">Италия · Minotti</div>
              <div class="cmp-price old">$14 000</div>
            </div>
          </div>
          <div class="cmp-cell china">
            <div class="cmp-photo" style="background-image:url('/images/product-sofa-china.jpg')"></div>
            <div>
              <div class="cmp-tag">Та же модель</div>
              <div class="cmp-origin">Китай · напрямую с фабрики</div>
              <div class="cmp-price accent">$4 200</div>
            </div>
          </div>
        </div>
      </div>

      <div class="cmp-row">
        <div class="cmp-head">
          <div class="cmp-model">Кресло Nepal</div>
          <div class="cmp-save">Выгода −70%</div>
        </div>
        <div class="cmp-pair">
          <div class="cmp-cell">
            <div class="cmp-photo" style="background-image:url('/images/product-chair-italy.jpg')"></div>
            <div>
              <div class="cmp-tag">Оригинал</div>
              <div class="cmp-origin">Италия · Baxter</div>
              <div class="cmp-price old">$9 500</div>
            </div>
          </div>
          <div class="cmp-cell china">
            <div class="cmp-photo" style="background-image:url('/images/product-chair-china.jpg')"></div>
            <div>
              <div class="cmp-tag">Та же модель</div>
              <div class="cmp-origin">Китай · напрямую с фабрики</div>
              <div class="cmp-price accent">$2 900</div>
            </div>
          </div>
        </div>
      </div>

      <div class="cmp-row">
        <div class="cmp-head">
          <div class="cmp-model">Кресло Up 50</div>
          <div class="cmp-save">Выгода −75%</div>
        </div>
        <div class="cmp-pair">
          <div class="cmp-cell">
            <div class="cmp-photo" style="background-image:url('/images/product-up5-italy.jpg')"></div>
            <div>
              <div class="cmp-tag">Оригинал</div>
              <div class="cmp-origin">Италия · B&amp;B Italia</div>
              <div class="cmp-price old">$12 000</div>
            </div>
          </div>
          <div class="cmp-cell china">
            <div class="cmp-photo" style="background-image:url('/images/product-up5-china.jpg')"></div>
            <div>
              <div class="cmp-tag">Та же модель</div>
              <div class="cmp-origin">Китай · напрямую с фабрики</div>
              <div class="cmp-price accent">$3 000</div>
            </div>
          </div>
        </div>
      </div>

      <div class="cmp-row">
        <div class="cmp-head">
          <div class="cmp-model">Кухонный стол Butterfly</div>
          <div class="cmp-save">Выгода −70%</div>
        </div>
        <div class="cmp-pair">
          <div class="cmp-cell">
            <div class="cmp-photo" style="background-image:url('/images/product-table-italy.jpg')"></div>
            <div>
              <div class="cmp-tag">Оригинал</div>
              <div class="cmp-origin">Италия · Tonin Casa</div>
              <div class="cmp-price old">$3 200</div>
            </div>
          </div>
          <div class="cmp-cell china">
            <div class="cmp-photo" style="background-image:url('/images/product-table-china.jpg')"></div>
            <div>
              <div class="cmp-tag">Та же модель</div>
              <div class="cmp-origin">Китай · напрямую с фабрики</div>
              <div class="cmp-price accent">$950</div>
            </div>
          </div>
        </div>
      </div>

      <div class="cmp-row">
        <div class="cmp-head">
          <div class="cmp-model">Кровать Rimini</div>
          <div class="cmp-save">Выгода −70%</div>
        </div>
        <div class="cmp-pair">
          <div class="cmp-cell">
            <div class="cmp-photo" style="background-image:url('/images/product-bed-italy.jpg')"></div>
            <div>
              <div class="cmp-tag">Оригинал</div>
              <div class="cmp-origin">Италия · Fratelli Barri</div>
              <div class="cmp-price old">$5 300</div>
            </div>
          </div>
          <div class="cmp-cell china">
            <div class="cmp-photo" style="background-image:url('/images/product-bed-china.jpg')"></div>
            <div>
              <div class="cmp-tag">Та же модель</div>
              <div class="cmp-origin">Китай · напрямую с фабрики</div>
              <div class="cmp-price accent">$1 600</div>
            </div>
          </div>
        </div>
      </div>

      <div class="cmp-row">
        <div class="cmp-head">
          <div class="cmp-model">Диван Aggi</div>
          <div class="cmp-save">Выгода −70%</div>
        </div>
        <div class="cmp-pair">
          <div class="cmp-cell">
            <div class="cmp-photo" style="background-image:url('/images/product-aggi-italy.jpg')"></div>
            <div>
              <div class="cmp-tag">Оригинал</div>
              <div class="cmp-origin">Франция · Hamilton Conte</div>
              <div class="cmp-price old">$7 000</div>
            </div>
          </div>
          <div class="cmp-cell china">
            <div class="cmp-photo" style="background-image:url('/images/product-aggi-china.jpg')"></div>
            <div>
              <div class="cmp-tag">Та же модель</div>
              <div class="cmp-origin">Китай · напрямую с фабрики</div>
              <div class="cmp-price accent">$2 100</div>
            </div>
          </div>
        </div>
      </div>

      <div class="cmp-row cmp-cta">
        <div>
          <div class="cmp-model">Ваша модель из списка</div>
          <p>Пришлите позицию или дизайн-проект — подберём ту&nbsp;же модель на&nbsp;фабрике в&nbsp;Китае и&nbsp;посчитаем цену.</p>
        </div>
        <a class="btn light" href="#contact">Рассчитать бесплатно <span class="btn-arrow">→</span></a>
      </div>
    </div>

    <div class="compare-foot reveal">
      <p>Вся мебель собирается по&nbsp;идентичной технологии при&nbsp;использовании таких&nbsp;же материалов.</p>
    </div>
  </div>
</section>

<section class="process" id="process">
  <div class="wrap">
    <div class="section-head reveal">
      <h2>Как проходит<br>работа</h2>
      <p>Семь этапов, которые проходит каждый проект — от&nbsp;чертежа до&nbsp;воплощения мечты.</p>
    </div>

    <div class="flow reveal">
      <div class="flow-node">Проект</div><div class="flow-arrow">→</div>
      <div class="flow-node">Договор</div><div class="flow-arrow">→</div>
      <div class="flow-node">Подбор производителей</div><div class="flow-arrow">→</div>
      <div class="flow-node">Производство</div><div class="flow-arrow">→</div>
      <div class="flow-node">Инспекция</div><div class="flow-arrow">→</div>
      <div class="flow-node">Консолидация</div><div class="flow-arrow">→</div>
      <div class="flow-node">Доставка</div>
    </div>

    <div class="process-subhead reveal">Детальный план комплектации объектов</div>

    <div class="process-list reveal">
      <div class="p-step">
        <h4>Проект</h4>
        <p>Получаем дизайн-проект, спецификацию или&nbsp;техническое задание и&nbsp;анализируем объём поставки. Бесплатный подбор 10&nbsp;наименований для&nbsp;понимания выгоды.</p>
      </div>
      <div class="p-step">
        <h4>Начало работы</h4>
        <p>Заключаем договор, фиксируем объём работ и&nbsp;после внесения депозита приступаем к&nbsp;подбору производителей.</p>
      </div>
      <div class="p-step">
        <h4>Подбор производителей</h4>
        <p>Формируем пул производителей под&nbsp;ваш проект, оценивая их производственные возможности, качество продукции, сроки изготовления и&nbsp;коммерческие условия.</p>
      </div>
      <div class="p-step">
        <h4>Производство</h4>
        <p>Размещаем заказы на&nbsp;согласованных фабриках. После внесения 50% предоплаты за&nbsp;продукцию производители запускают изготовление заказа.</p>
      </div>
      <div class="p-step">
        <h4>Инспекция</h4>
        <p>Проводим проверку качества, комплектности и&nbsp;соответствия продукции перед отгрузкой. Предоставляем фото и&nbsp;видеоотчёты. После подтверждения результатов инспекции вносятся оставшиеся 50% оплаты за&nbsp;продукцию.</p>
      </div>
      <div class="p-step">
        <h4>Консолидация</h4>
        <p>Доставляем продукцию от&nbsp;всех производителей на&nbsp;консолидационный склад, проверяем артикулы на&nbsp;скрытые дефекты и&nbsp;комплектность, объединяем груз и&nbsp;подготавливаем его к&nbsp;международной отправке.</p>
      </div>
      <div class="p-step">
        <h4>Доставка</h4>
        <p>Организуем международную перевозку, таможенное оформление через партнёров и&nbsp;доставку груза до&nbsp;объекта в&nbsp;согласованные сроки.</p>
      </div>
    </div>
  </div>
</section>

<section id="cases">
  <div class="wrap">
    <div class="section-head reveal">
      <h2>Кейсы</h2>
      <p>Несколько проектов, реализованных под&nbsp;ключ через прямую комплектацию из&nbsp;Китая.</p>
    </div>
    <div class="cases-scroll reveal">
      <div class="case-card">
        <div class="case-bg" style="background-image:url('/images/obj-house.jpg')"></div>
        <div class="case-overlay"></div>
        <div class="case-content">
          <div>
            <div class="case-tag">Частный дом</div>
            <h4>Полная комплектация</h4>
            <p>Мебель, освещение и отделочные материалы для дома под ключ.</p>
          </div>
          <div class="case-stats">
            <div><span class="label">Подробности</span><span class="value details-link">Смотреть →</span></div>
            <div><span class="label">Общий чек</span><span class="value">$86 000</span></div>
          </div>
        </div>
      </div>
      <div class="case-card">
        <div class="case-bg" style="background-image:url('/images/obj-apartments.jpg')"></div>
        <div class="case-overlay"></div>
        <div class="case-content">
          <div>
            <div class="case-tag">Апартаменты</div>
            <h4>Мебель и декор</h4>
            <p>Подбор мебели и декоративных решений под готовый дизайн-проект.</p>
          </div>
          <div class="case-stats">
            <div><span class="label">Подробности</span><span class="value details-link">Смотреть →</span></div>
            <div><span class="label">Общий чек</span><span class="value">$41 500</span></div>
          </div>
        </div>
      </div>
      <div class="case-card">
        <div class="case-bg" style="background-image:url('/images/hero.jpg')"></div>
        <div class="case-overlay"></div>
        <div class="case-content">
          <div>
            <div class="case-tag">Коммерческий объект</div>
            <h4>Общественные пространства</h4>
            <p>Комплектация рабочих зон и общественных пространств объекта.</p>
          </div>
          <div class="case-stats">
            <div><span class="label">Подробности</span><span class="value details-link">Смотреть →</span></div>
            <div><span class="label">Общий чек</span><span class="value">$132 000</span></div>
          </div>
        </div>
      </div>
      <div class="case-card">
        <div class="case-bg" style="background-image:url('/images/obj-hotel.jpg')"></div>
        <div class="case-overlay"></div>
        <div class="case-content">
          <div>
            <div class="case-tag">Отель</div>
            <h4>Номерной фонд</h4>
            <p>Комплектация типовых номеров по единой спецификации.</p>
          </div>
